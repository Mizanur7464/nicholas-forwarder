# Telegram Bot Token (from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Master channel ID (Lazytradeclubmain)
# ID পেতে: চ্যানেল থেকে যেকোনো পোস্ট @userinfobot-এ ফরওয়ার্ড করুন
SOURCE_CHANNEL_ID=-100xxxxxxxxxx

# Forward channel IDs (comma-separated, no spaces)
# Forward 1: Lazytradeclubofficial | Forward 2: Lazytradeclubchannel
DESTINATION_CHANNEL_IDS=-100xxxxxxxxxx,-100xxxxxxxxxx

# true = copy without "forwarded" label, false = forward with label
COPY_WITHOUT_FORWARD_LABEL=true
